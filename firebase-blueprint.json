{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "A Padel tournament",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the tournament" },
        "mode": { "type": "string", "enum": ["Round Robin", "Single Elimination"], "description": "Game mode" },
        "creatorId": { "type": "string", "description": "UID of the creator" },
        "status": { "type": "string", "enum": ["active", "completed"], "description": "Current status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "players": { "type": "array", "items": { "type": "string" }, "description": "List of player names" }
      },
      "required": ["name", "mode", "creatorId", "status", "createdAt", "players"]
    },
    "Match": {
      "title": "Match",
      "description": "A single match in a tournament",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string", "description": "ID of the parent tournament" },
        "team1": { "type": "array", "items": { "type": "string" }, "description": "Players in team 1" },
        "team2": { "type": "array", "items": { "type": "string" }, "description": "Players in team 2" },
        "score1": { "type": "integer", "description": "Current games won by team 1 in current set" },
        "score2": { "type": "integer", "description": "Current games won by team 2 in current set" },
        "sets1": { "type": "array", "items": { "type": "integer" }, "description": "Sets won by team 1" },
        "sets2": { "type": "array", "items": { "type": "integer" }, "description": "Sets won by team 2" },
        "serverIndex": { "type": "integer", "description": "Index of the current server (0-3)" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"], "description": "Match status" },
        "winner": { "type": "integer", "description": "1 or 2 if completed" }
      },
      "required": ["tournamentId", "team1", "team2", "score1", "score2", "sets1", "sets2", "serverIndex", "status"]
    }
  },
  "firestore": {
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Collection of tournaments"
    },
    "/tournaments/{tournamentId}/matches/{matchId}": {
      "schema": "Match",
      "description": "Sub-collection of matches for a tournament"
    }
  }
}
